{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CodeHubStabilityFixCase",
  "description": "Stability fix mined from CodeHub merge request (Mode B only)",
  "type": "object",
  "required": [
    "case_id",
    "project",
    "mr_iid",
    "stability_class",
    "problem_description",
    "before_commit_sha",
    "after_commit_sha"
  ],
  "properties": {
    "case_id": { "type": "string" },
    "project": { "type": "string" },
    "mr_iid": { "type": "integer" },
    "title": { "type": "string" },
    "state": { "type": "string" },
    "web_url": { "type": "string" },
    "author": { "type": "string" },
    "merged_at": { "type": ["string", "null"] },
    "source": { "const": "codehub_stability" },
    "stability_class": {
      "enum": [
        "appfreeze",
        "jserror",
        "jsleak",
        "memoryleak",
        "appcrash",
        "thread_leak",
        "fd_leak",
        "asan",
        "general"
      ]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "matched_keywords": { "type": "array", "items": { "type": "string" } },
    "problem_description": { "type": "string" },
    "before_commit_sha": { "type": "string" },
    "after_commit_sha": { "type": "string" },
    "unified_diff": { "type": "string" },
    "changed_files": { "type": "array", "items": { "type": "string" } },
    "commit_messages": { "type": "array", "items": { "type": "string" } },
    "code_changes": {
      "type": "array",
      "items": { "$ref": "#/definitions/code_change" }
    },
    "fetched_at": { "type": "string", "format": "date-time" }
  },
  "definitions": {
    "code_change": {
      "type": "object",
      "required": ["file_path"],
      "properties": {
        "file_path": { "type": "string" },
        "code_before": { "type": ["string", "null"] },
        "code_after": { "type": ["string", "null"] },
        "file_diff": { "type": "string" },
        "truncated": { "type": "boolean", "default": false }
      }
    }
  }
}
